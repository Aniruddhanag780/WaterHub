rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * HydroTrack Security Rules
     *
     * Core Philosophy:
     * This ruleset enforces a strict user-ownership model. The application data is organized 
     * hierarchically under a root /users/{userId} path, ensuring that all data is siloed 
     * by the authenticated user's unique ID (UID).
     *
     * Data Structure:
     * - /users/{userId}: Root user document containing core account info.
     * - /users/{userId}/profile/profile: A 1:1 sub-document for hydration goals and units.
     * - /users/{userId}/reminderSetting/reminderSetting: A 1:1 sub-document for notification preferences.
     * - /users/{userId}/waterIntakes/{id}: A collection of hydration logs.
     * - /users/{userId}/dailySummaries/{id}: A collection of aggregated daily stats.
     *
     * Key Security Decisions:
     * - Authorization Independence: Documents in subcollections (waterIntakes, dailySummaries) 
     *   contain a denormalized 'userId' field. This allows rules to verify ownership by 
     *   comparing the auth UID to both the path segment and the internal field, preventing 
     *   cross-user data injection.
     * - Prototyping Flexibility: These rules focus exclusively on identity-based authorization 
     *   and relational integrity (matching UIDs). They do not enforce strict schema types 
     *   (strings, numbers) to allow for rapid frontend iteration.
     * - Strict Ownership: No public reading or listing is permitted. Users can only access 
     *   their own data tree.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if a document exists and if the user is the owner. Used for updates and deletes. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root User document.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document /users/abc where data.id == 'abc'.
     * @deny (create) User 'abc' attempts to create document /users/xyz.
     * @principle Ownership and Self-Creation.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the 1:1 UserProfile document.
     * @path /users/{userId}/profile/profile
     * @allow (get) User 'abc' retrieves their profile.
     * @deny (update) User 'abc' attempts to change the 'userId' field of the profile.
     * @principle Relational integrity and path-based ownership.
     */
    match /users/{userId}/profile/profile {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for logging water intake records.
     * @path /users/{userId}/waterIntakes/{waterIntakeId}
     * @allow (list) User 'abc' queries their own water intake history.
     * @deny (create) User 'abc' attempts to log water for user 'xyz'.
     * @principle Ownership validation via path and denormalized field.
     */
    match /users/{userId}/waterIntakes/{waterIntakeId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the 1:1 ReminderSetting document.
     * @path /users/{userId}/reminderSetting/reminderSetting
     * @allow (update) User 'abc' toggles their own reminders.
     * @deny (delete) Anonymous user attempts to delete a reminder setting.
     * @principle Immutable ownership field and path-based access control.
     */
    match /users/{userId}/reminderSetting/reminderSetting {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for the DailySummary collection.
     * @path /users/{userId}/dailySummaries/{dailySummaryId}
     * @allow (get) User 'abc' views their summary for '2023-10-27'.
     * @deny (update) User 'abc' attempts to change the 'userId' associated with a summary.
     * @principle Consistency between authentication state, path segments, and document data.
     */
    match /users/{userId}/dailySummaries/{dailySummaryId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }
  }
}