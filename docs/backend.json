
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account within the WaterHub application.",
      "properties": {
        "id": {
          "type": "string"
        },
        "externalAuthId": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "displayName": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "externalAuthId",
        "email",
        "createdAt",
        "updatedAt"
      ]
    },
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Stores personalized settings and preferences for a user.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "dailyGoalMl": {
          "type": "number"
        },
        "isDriveLinked": {
          "type": "boolean"
        },
        "preferredUnit": {
          "type": "string"
        },
        "wakeUpTime": {
          "type": "string",
          "format": "time"
        },
        "sleepTime": {
          "type": "string",
          "format": "time"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "userId",
        "dailyGoalMl",
        "isDriveLinked",
        "createdAt",
        "updatedAt"
      ]
    },
    "AppNotification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppNotification",
      "type": "object",
      "description": "Records non-water related system events and user actions for notification tracking.",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["login", "logout", "drive_connected", "goal_updated"]
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed"]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "userId", "type", "title", "status", "timestamp"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous",
      "google.com"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Stores core user account information."
        }
      },
      {
        "path": "/users/{userId}/profile/profile",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "Stores user settings and preferences."
        }
      },
      {
        "path": "/users/{userId}/notifications/{notificationId}",
        "definition": {
          "entityName": "AppNotification",
          "schema": {
            "$ref": "#/backend/entities/AppNotification"
          },
          "description": "Stores system and account activity notifications."
        }
      }
    ]
  }
}
